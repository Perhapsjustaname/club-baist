@page "/standing"
@using ClubBaist.Data
@using ClubBaist.Models
@using ClubBaist.Services
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject UserService UserServ
@inject TeeTimeService TeeTimeSvc
@inject IDbContextFactory<ClubBaistDbContext> DBFactory
@inject AuditService AuditSvc

<PageTitle>Standing Tee Time — Club BAIST</PageTitle>

@if (!UserServ.IsLoggedIn)
{
    <div class="alert alert-warning">
        <i class="bi bi-lock-fill me-2"></i>
        Please <a href="/login" class="fw-bold">sign in</a> to manage your standing tee time.
    </div>
}
else if (memberProfile == null)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle-fill me-2"></i>
        No member profile found. Please contact the pro shop.
    </div>
}
else if (memberProfile.Tier != MembershipTier.Gold)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        Standing tee time requests are only available to <strong>Gold</strong> members.
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h1 class="page-header-title">Standing Tee Time</h1>
            <p class="page-header-sub">Request a recurring weekly tee time for the season</p>
        </div>
        @if (memberProfile.IsGoldShareholder)
        {
            <button class="btn btn-gold" @onclick="() => showForm = !showForm">
                <i class="bi @(showForm ? "bi-x-lg" : "bi-plus-lg") me-2"></i>@(showForm ? "Cancel" : "New Request")
            </button>
        }
    </div>

    @* associates can be in someone else's group but cant submit their own *@
    @if (!memberProfile.IsGoldShareholder)
    {
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle-fill me-2"></i>
            Standing requests may only be submitted by <strong>Gold Shareholders</strong>.
            You may be included as a playing partner in a Shareholder's group.
        </div>
    }

    <!-- submission form, shareholder only -->
    @if (showForm && memberProfile.IsGoldShareholder)
    {
        <div class="card mb-4">
            <div class="card-header-golf">
                <h5><i class="bi bi-repeat me-2"></i>New Standing Request</h5>
            </div>
            <div class="card-body">

                @if (!string.IsNullOrEmpty(formMsg))
                {
                    <div class="alert @(formSuccess ? "alert-success" : "alert-danger") py-2">
                        <i class="bi @(formSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>@formMsg
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Day of Week *</label>
                        <select class="form-select" @bind="reqDayOfWeek">
                            @foreach (var d in Enum.GetValues<DayOfWeek>())
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Preferred Start Time *</label>
                        <select class="form-select" @bind="reqTimeStr">
                            @foreach (var s in TeeTimeSvc.GetAllSlots())
                            {
                                <option value="@s.ToString("HH:mm")">@s.ToString("h:mm tt")</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Start Date *</label>
                        <input type="date" class="form-control"
                               value="@reqStartDate.ToString("yyyy-MM-dd")"
                               @onchange="e => TrySetDate(e.Value?.ToString(), ref reqStartDate)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">End Date *</label>
                        <input type="date" class="form-control"
                               value="@reqEndDate.ToString("yyyy-MM-dd")"
                               @onchange="e => TrySetDate(e.Value?.ToString(), ref reqEndDate)" />
                    </div>
                </div>

                <!-- optional playing partners -->
                <div class="mt-3 mb-2">
                    <label class="form-label" style="font-size:0.8rem; font-weight:600; color:var(--cb-green-dark); text-transform:uppercase; letter-spacing:0.06em;">
                        Playing Partners (optional — up to 3)
                    </label>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div style="border:1px solid var(--cb-border); border-radius:6px; padding:10px;">
                            <div style="font-size:0.74rem; font-weight:600; color:var(--cb-muted); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:6px;">Player 2</div>
                            <input class="form-control form-control-sm mb-1" placeholder="Name" @bind="p2Name" />
                            <input class="form-control form-control-sm" placeholder="Member # (optional)" @bind="p2Number" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div style="border:1px solid var(--cb-border); border-radius:6px; padding:10px;">
                            <div style="font-size:0.74rem; font-weight:600; color:var(--cb-muted); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:6px;">Player 3</div>
                            <input class="form-control form-control-sm mb-1" placeholder="Name" @bind="p3Name" />
                            <input class="form-control form-control-sm" placeholder="Member # (optional)" @bind="p3Number" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div style="border:1px solid var(--cb-border); border-radius:6px; padding:10px;">
                            <div style="font-size:0.74rem; font-weight:600; color:var(--cb-muted); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:6px;">Player 4</div>
                            <input class="form-control form-control-sm mb-1" placeholder="Name" @bind="p4Name" />
                            <input class="form-control form-control-sm" placeholder="Member # (optional)" @bind="p4Number" />
                        </div>
                    </div>
                </div>

                <div class="mt-3 d-flex align-items-center gap-3">
                    <button class="btn btn-gold px-4" disabled="@isSubmitting" @onclick="SubmitRequest">
                        @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        <i class="bi bi-send-fill me-2"></i>Submit Request
                    </button>
                    <span style="font-size:0.78rem; color:var(--cb-muted);">
                        <i class="bi bi-info-circle me-1"></i>
                        The Tee Time Committee will review your request and assign a time based on priority.
                    </span>
                </div>
            </div>
        </div>
    }

    <!-- member's existing requests -->
    <div class="card">
        <div class="card-header-golf">
            <h5><i class="bi bi-list-check me-2"></i>My Standing Requests</h5>
        </div>
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border spinner-border-sm" role="status" style="color:var(--cb-green);"></div>
                </div>
            }
            else if (!myRequests.Any())
            {
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-calendar-x" style="font-size:2rem; opacity:0.4;"></i>
                    <p class="mt-2 mb-0" style="font-size:0.88rem;">No standing requests on file.</p>
                </div>
            }
            else
            {
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>Preferred Time</th>
                            <th>Season Window</th>
                            <th>Players</th>
                            <th>Status</th>
                            <th>Assigned Time / Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in myRequests)
                        {
                            <tr>
                                <td style="font-weight:600;">@r.RequestedDayOfWeek</td>
                                <td>@r.RequestedTime.ToString("h:mm tt")</td>
                                <td style="font-size:0.82rem;">
                                    @r.StartDate.ToString("MMM d") – @r.EndDate.ToString("MMM d, yyyy")
                                </td>
                                <td style="font-size:0.82rem;">@FormatPlayers(r)</td>
                                <td>
                                    <span class="status-chip @StatusBadge(r.Status)">@r.Status</span>
                                </td>
                                <td>
                                    @if (r.Status == RequestStatus.Approved && r.ApprovedTime.HasValue)
                                    {
                                        <strong style="color:var(--cb-green-dark);">
                                            @r.ApprovedTime.Value.ToString("h:mm tt")
                                        </strong>
                                        <span style="font-size:0.75rem; color:var(--cb-muted); margin-left:6px;">
                                            Priority #@r.PriorityNumber
                                        </span>
                                    }
                                    else if (r.Status == RequestStatus.Declined)
                                    {
                                        <span style="font-size:0.8rem; color:var(--cb-muted);">
                                            @(r.DeclinedReason ?? "No reason provided")
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="font-size:0.82rem; color:var(--cb-muted);">Pending review</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    MemberProfile? memberProfile;
    private List<StandingTeeTimeRequest> myRequests = new();
    bool showForm     = false;
    bool isLoading    = true;
    bool isSubmitting = false;
    string formMsg    = "";
    bool formSuccess  = false;

    // form fields
    DayOfWeek reqDayOfWeek = DayOfWeek.Saturday;
    string reqTimeStr      = "07:00";
    DateOnly reqStartDate  = new DateOnly(DateTime.Now.Year, 3, 1);
    DateOnly reqEndDate    = new DateOnly(DateTime.Now.Year, 9, 30);
    string p2Name = "", p2Number = "", p3Name = "", p3Number = "", p4Name = "", p4Number = "";

    protected override async Task OnInitializedAsync()
    {
        if (!UserServ.IsLoggedIn) return;
        await using var db = DBFactory.CreateDbContext();
        memberProfile = await db.MemberProfiles
            .FirstOrDefaultAsync(m => m.UserId == UserServ.CurrentUser!.UserId);

        if (memberProfile != null)
            await LoadRequests();
    }

    private async Task LoadRequests()
    {
        isLoading = true;
        myRequests = await TeeTimeSvc.GetMemberStandingRequestsAsync(memberProfile!.MemberProfileId);
        isLoading = false;
    }

    private async Task SubmitRequest()
    {
        formMsg = "";
        if (!TimeOnly.TryParse(reqTimeStr, out var time))
        {
            formMsg = "Invalid time selection.";
            formSuccess = false;
            return;
        }

        isSubmitting = true;
        var error = await TeeTimeSvc.SubmitStandingRequestAsync(
            memberProfile!.MemberProfileId,
            reqDayOfWeek, time, reqStartDate, reqEndDate,
            p2Number, p2Name,
            p3Number, p3Name,
            p4Number, p4Name);

        if (error != null)
        {
            formMsg = error;
            formSuccess = false;
        }
        else
        {
            await AuditSvc.LogAsync(
                UserServ.CurrentUser!.Username,
                "SubmitStandingRequest",
                "StandingTeeTimeRequest",
                null,
                $"Submitted standing request for {reqDayOfWeek} at {time:h\\:mm tt} ({reqStartDate:MMM d} \u2013 {reqEndDate:MMM d, yyyy})"
            );
            formMsg = "Request submitted. The Tee Time Committee will review it and assign a time based on priority.";
            formSuccess = true;
            showForm = false;
            p2Name = p2Number = p3Name = p3Number = p4Name = p4Number = "";
            await LoadRequests();
        }
        isSubmitting = false;
    }

    // helper so date inputs work without full bind overhead
    private void TrySetDate(string? val, ref DateOnly field)
    {
        if (DateOnly.TryParse(val, out var d))
            field = d;
    }

    private string FormatPlayers(StandingTeeTimeRequest r)
    {
        int total = 1;
        if (!string.IsNullOrEmpty(r.Member2Name)) total++;
        if (!string.IsNullOrEmpty(r.Member3Name)) total++;
        if (!string.IsNullOrEmpty(r.Member4Name)) total++;
        return total == 1 ? "Solo" : $"{total} players";
    }

    private string StatusBadge(RequestStatus s) => s switch
    {
        RequestStatus.Approved => "badge-green",
        RequestStatus.Declined => "badge-silver",
        _                      => "badge-gold"   // pending = gold highlight
    };
}
