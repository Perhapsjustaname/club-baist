@page "/admin/standing"
@using ClubBaist.Data
@using ClubBaist.Models
@using ClubBaist.Services
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject UserService UserServ
@inject TeeTimeService TeeTimeSvc
@inject AuditService AuditSvc

<PageTitle>Standing Tee Time Requests — Club BAIST Admin</PageTitle>

@if (!IsAuthorized())
{
    <div class="alert alert-danger">
        <i class="bi bi-lock-fill me-2"></i>Access denied. Admin or Staff role required.
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h1 class="page-header-title">Standing Tee Time Requests</h1>
            <p class="page-header-sub">@pending.Count pending · @approved.Count approved · @declined.Count declined</p>
        </div>
    </div>

    <!-- stats row -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card" style="border-left-color:var(--cb-gold);">
                <div class="stat-value">@pending.Count</div>
                <div class="stat-label">Pending Review</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="border-left-color:var(--cb-green);">
                <div class="stat-value">@approved.Count</div>
                <div class="stat-label">Approved</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="border-left-color:#aaa;">
                <div class="stat-value">@declined.Count</div>
                <div class="stat-label">Declined</div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(actionMsg))
    {
        <div class="alert @(actionSuccess ? "alert-success" : "alert-danger") py-2 mb-3">
            <i class="bi @(actionSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>@actionMsg
        </div>
    }

    <!-- PENDING SECTION -->
    <div class="card mb-4">
        <div class="card-header-golf d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-hourglass-split me-2"></i>Pending Requests</h5>
            <span style="font-size:0.75rem; color:rgba(255,255,255,0.6);">Assign priority and time, then approve or decline</span>
        </div>
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border spinner-border-sm" role="status" style="color:var(--cb-green);"></div>
                </div>
            }
            else if (!pending.Any())
            {
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-check2-all" style="font-size:2rem; opacity:0.4;"></i>
                    <p class="mt-2 mb-0" style="font-size:0.88rem;">No pending requests.</p>
                </div>
            }
            else
            {
                @foreach (var r in pending)
                {
                    <div class="px-4 py-3" style="border-bottom:1px solid var(--cb-border);">
                        <!-- request summary -->
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                            <div>
                                <div style="font-weight:600;">
                                    @r.PrimaryMemberProfile.FullName
                                    <span style="font-family:monospace; font-size:0.78rem; color:var(--cb-muted); margin-left:6px;">
                                        #@r.PrimaryMemberProfile.MemberNumber
                                    </span>
                                </div>
                                <div style="font-size:0.82rem; color:var(--cb-muted);">
                                    <strong>@r.RequestedDayOfWeek</strong> &bull;
                                    Preferred: @r.RequestedTime.ToString("h:mm tt") &bull;
                                    @r.StartDate.ToString("MMM d") – @r.EndDate.ToString("MMM d, yyyy") &bull;
                                    @FormatPlayers(r)
                                </div>
                                @if (!string.IsNullOrEmpty(r.Member2Name))
                                {
                                    <div style="font-size:0.78rem; color:var(--cb-muted); margin-top:2px;">
                                        Partners: @r.Member2Name
                                        @if (!string.IsNullOrEmpty(r.Member3Name)) { <span> · @r.Member3Name</span> }
                                        @if (!string.IsNullOrEmpty(r.Member4Name)) { <span> · @r.Member4Name</span> }
                                    </div>
                                }
                            </div>
                            <span class="status-chip badge-gold">Pending</span>
                        </div>

                        <!-- approve form (always visible for pending rows) -->
                        <div class="row g-2 align-items-end" style="max-width:650px;">
                            <div class="col-auto">
                                <label class="form-label mb-1" style="font-size:0.75rem;">Priority #</label>
                                <input type="number" class="form-control form-control-sm" style="width:80px;"
                                       min="1" max="99"
                                       value="@GetPriorityInput(r.RequestId)"
                                       @onchange="e => SetPriorityInput(r.RequestId, e.Value?.ToString())" />
                            </div>
                            <div class="col-auto">
                                <label class="form-label mb-1" style="font-size:0.75rem;">Assigned Time</label>
                                <select class="form-select form-select-sm" style="width:140px;"
                                        value="@GetTimeInput(r.RequestId)"
                                        @onchange="e => SetTimeInput(r.RequestId, e.Value?.ToString())">
                                    @foreach (var s in TeeTimeSvc.GetAllSlots())
                                    {
                                        <option value="@s.ToString("HH:mm")">@s.ToString("h:mm tt")</option>
                                    }
                                </select>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-outline-green"
                                        disabled="@(processingId == r.RequestId)"
                                        @onclick="() => Approve(r.RequestId)">
                                    @if (processingId == r.RequestId) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    <i class="bi bi-check2 me-1"></i>Approve
                                </button>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-outline-danger"
                                        disabled="@(processingId == r.RequestId)"
                                        @onclick="() => ToggleDeclineInput(r.RequestId)">
                                    <i class="bi bi-x me-1"></i>Decline
                                </button>
                            </div>
                        </div>

                        <!-- decline reason input, shown when staff clicks Decline -->
                        @if (declineInputId == r.RequestId)
                        {
                            <div class="row g-2 mt-2 align-items-end" style="max-width:500px;">
                                <div class="col">
                                    <input class="form-control form-control-sm"
                                           placeholder="Reason for declining (optional)"
                                           @bind="declineReason" />
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-sm btn-danger"
                                            @onclick="() => Decline(r.RequestId)">
                                        Confirm Decline
                                    </button>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-sm btn-outline-secondary"
                                            @onclick="() => declineInputId = 0">Cancel</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- APPROVED SECTION -->
    <div class="card mb-4">
        <div class="card-header-golf">
            <h5 class="mb-0"><i class="bi bi-check-circle-fill me-2"></i>Approved Requests</h5>
        </div>
        <div class="card-body p-0">
            @if (!approved.Any())
            {
                <div class="p-4 text-center text-muted" style="font-size:0.88rem;">No approved requests.</div>
            }
            else
            {
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Member</th>
                            <th>Day</th>
                            <th>Assigned Time</th>
                            <th>Priority</th>
                            <th>Season</th>
                            <th>Players</th>
                            <th>Approved By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in approved)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600; font-size:0.88rem;">@r.PrimaryMemberProfile.FullName</div>
                                    <div style="font-size:0.75rem; color:var(--cb-muted);">@r.PrimaryMemberProfile.MemberNumber</div>
                                </td>
                                <td style="font-weight:600;">@r.RequestedDayOfWeek</td>
                                <td style="font-weight:700; color:var(--cb-green-dark);">
                                    @(r.ApprovedTime?.ToString("h:mm tt") ?? "—")
                                </td>
                                <td style="font-weight:700;">#@r.PriorityNumber</td>
                                <td style="font-size:0.82rem;">@r.StartDate.ToString("MMM d") – @r.EndDate.ToString("MMM d, yyyy")</td>
                                <td style="font-size:0.82rem;">@FormatPlayers(r)</td>
                                <td style="font-size:0.82rem; color:var(--cb-muted);">
                                    @r.ApprovedBy
                                    <div>@r.ApprovedDate?.ToString("MMM d, yyyy")</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- DECLINED SECTION -->
    @if (declined.Any())
    {
        <div class="card">
            <div class="card-header-golf">
                <h5 class="mb-0"><i class="bi bi-x-circle-fill me-2"></i>Declined Requests</h5>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Member</th>
                            <th>Day Requested</th>
                            <th>Preferred Time</th>
                            <th>Declined By</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in declined)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600; font-size:0.88rem;">@r.PrimaryMemberProfile.FullName</div>
                                    <div style="font-size:0.75rem; color:var(--cb-muted);">@r.PrimaryMemberProfile.MemberNumber</div>
                                </td>
                                <td>@r.RequestedDayOfWeek</td>
                                <td>@r.RequestedTime.ToString("h:mm tt")</td>
                                <td style="font-size:0.82rem; color:var(--cb-muted);">
                                    @r.ApprovedBy · @r.ApprovedDate?.ToString("MMM d, yyyy")
                                </td>
                                <td style="font-size:0.82rem;">@(r.DeclinedReason ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private List<StandingTeeTimeRequest> pending  = new();
    private List<StandingTeeTimeRequest> approved = new();
    private List<StandingTeeTimeRequest> declined = new();
    bool isLoading   = true;
    string actionMsg = "";
    bool actionSuccess = true;

    // per-row approve inputs stored by requestId
    private Dictionary<int, int> priorityInputs = new();
    private Dictionary<int, string> timeInputs   = new();

    // which row is showing the decline reason form
    int declineInputId = 0;
    string declineReason = "";

    // which request is currently being processed (shows spinner)
    int processingId = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();
    }

    private async Task LoadRequests()
    {
        isLoading = true;
        var all = await TeeTimeSvc.GetAllStandingRequestsAsync();
        pending  = all.Where(r => r.Status == RequestStatus.Pending).ToList();
        approved = all.Where(r => r.Status == RequestStatus.Approved).OrderBy(r => r.RequestedDayOfWeek).ThenBy(r => r.PriorityNumber).ToList();
        declined = all.Where(r => r.Status == RequestStatus.Declined).ToList();

        // seed default approve form values for each pending request
        foreach (var r in pending)
        {
            if (!priorityInputs.ContainsKey(r.RequestId))
                priorityInputs[r.RequestId] = 1;
            if (!timeInputs.ContainsKey(r.RequestId))
                timeInputs[r.RequestId] = r.RequestedTime.ToString("HH:mm");
        }

        isLoading = false;
    }

    private async Task Approve(int requestId)
    {
        processingId = requestId;
        actionMsg    = "";

        string timeStr = GetTimeInput(requestId);
        if (!TimeOnly.TryParse(timeStr, out var approvedTime))
        {
            await ShowMessage("Invalid time selected.", false);
            processingId = 0;
            return;
        }

        int priority = GetPriorityInput(requestId);
        var (success, message, _) = await TeeTimeSvc.ApproveStandingRequestAsync(
            requestId, approvedTime, priority, UserServ.CurrentUser!.Username);

        if (success)
        {
            await AuditSvc.LogAsync(
                UserServ.CurrentUser!.Username,
                "ApproveStandingRequest",
                "StandingTeeTimeRequest",
                requestId,
                $"Approved at {approvedTime:h\\:mm tt}, priority #{priority}. {message}"
            );
        }

        await ShowMessage(message, success);
        processingId = 0;
        await LoadRequests();
    }

    private void ToggleDeclineInput(int requestId)
    {
        // toggle off if clicking decline again on same row
        declineInputId = declineInputId == requestId ? 0 : requestId;
        declineReason  = "";
    }

    private async Task Decline(int requestId)
    {
        bool ok = await TeeTimeSvc.DeclineStandingRequestAsync(
            requestId, UserServ.CurrentUser!.Username, declineReason);

        if (ok)
        {
            await AuditSvc.LogAsync(
                UserServ.CurrentUser!.Username,
                "DeclineStandingRequest",
                "StandingTeeTimeRequest",
                requestId,
                $"Declined. Reason: {(string.IsNullOrEmpty(declineReason) ? "none given" : declineReason)}"
            );
        }

        declineInputId = 0;
        declineReason  = "";
        await ShowMessage(ok ? "Request declined." : "Could not decline that request.", ok);
        await LoadRequests();
    }

    // auto-clears message after 4 seconds
    private async Task ShowMessage(string msg, bool success)
    {
        actionMsg     = msg;
        actionSuccess = success;
        StateHasChanged();
        await Task.Delay(4000);
        actionMsg = "";
        StateHasChanged();
    }

    // approve form field helpers
    private int GetPriorityInput(int id) =>
        priorityInputs.TryGetValue(id, out var v) ? v : 1;

    private void SetPriorityInput(int id, string? val)
    {
        if (int.TryParse(val, out var n))
            priorityInputs[id] = n;
    }

    private string GetTimeInput(int id) =>
        timeInputs.TryGetValue(id, out var v) ? v : "07:00";

    private void SetTimeInput(int id, string? val)
    {
        if (!string.IsNullOrEmpty(val))
            timeInputs[id] = val;
    }

    private string FormatPlayers(StandingTeeTimeRequest r)
    {
        int total = 1;
        if (!string.IsNullOrEmpty(r.Member2Name)) total++;
        if (!string.IsNullOrEmpty(r.Member3Name)) total++;
        if (!string.IsNullOrEmpty(r.Member4Name)) total++;
        return total == 1 ? "Solo" : $"{total} players";
    }

    private bool IsAuthorized() => UserServ.CurrentUser?.Role is "Admin" or "Staff";
}
