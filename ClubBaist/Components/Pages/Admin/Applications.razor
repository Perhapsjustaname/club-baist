@page "/admin/applications"
@using ClubBaist.Data
@using ClubBaist.Models
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject UserService UserServ
@inject IDbContextFactory<ClubBaistDbContext> DBFactory
@inject AuditService AuditSvc

<PageTitle>Membership Applications — Club BAIST Admin</PageTitle>
@* check auth level incassae the user tries something *@
@if (!IsAuthorized())
{
    <div class="alert alert-danger">
        <i class="bi bi-lock-fill me-2"></i>Access denied. Admin or Staff role required.
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h1 class="page-header-title">Membership Applications</h1>
            <p class="page-header-sub">@applications.Count total applications</p>
        </div>
    </div>

    <!-- summarized statsq-->
    <div class="row g-3 mb-4">
        @foreach (var status in Enum.GetValues<ApplicationStatus>())
        {
            int count = applications.Count(a => a.Status == status);
            <div class="col-md-2">
                <div class="stat-card" style="border-left-color:@StatusColor(status);">
                    <div class="stat-value">@count</div>
                    <div class="stat-label" style="font-size:0.72rem;">@status</div>
                </div>
            </div>
        }
    </div>

    <!--code for filters -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row align-items-center g-2">
                <div class="col-md-4">
                    <input class="form-control" @bind="searchTerm" placeholder="Search by name or email..." @bind:event="oninput" />
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="filterStatus">
                        <option value="">All Statuses</option>
                        @foreach (var s in Enum.GetValues<ApplicationStatus>()) {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(actionMsg))
    {
        <div class="alert alert-success py-2 mb-3">
            <i class="bi bi-check-circle-fill me-2"></i>@actionMsg
        </div>
    }

    <!-- list apps -->
    @if (!FilteredApplications().Any())
    {
        <div class="card">
            <div class="card-body text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size:3rem; opacity:0.4;"></i>
                <p class="mt-3 mb-0">No applications found.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var app in FilteredApplications())
        {
            <div class="card mb-3 @(expandedId == app.ApplicationId ? "border-2" : "")"
                 style="@(expandedId == app.ApplicationId ? "border-color:var(--cb-gold);" : "")">
                <!-- header row -->
                <div class="card-body py-3 d-flex align-items-center"
                     style="cursor:pointer;"
                     @onclick="() => ToggleExpand(app.ApplicationId)">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2">
                            <span style="font-weight:700; font-size:1rem; color:var(--cb-green-dark);">@app.FullName</span>
                            <span class="status-chip" style="font-size:0.72rem; background:@StatusBg(app.Status); color:@StatusTextColor(app.Status);">
                                @app.Status
                            </span>
                            <span class="status-chip badge-silver" style="font-size:0.72rem;">@app.RequestedType</span>
                        </div>
                        <div style="font-size:0.8rem; color:var(--cb-muted); margin-top:2px;">
                            @app.Email &bull; Submitted @app.SubmittedAt.ToString("MMM d, yyyy")
                            @if (app.ReviewedBy != null) { <span> &bull; Reviewed by @app.ReviewedBy on @app.ReviewedAt?.ToString("MMM d")</span> }
                        </div>
                    </div>
                    <div class="ms-3">
                        <i class="bi @(expandedId == app.ApplicationId ? "bi-chevron-up" : "bi-chevron-down")" style="color:var(--cb-muted);"></i>
                    </div>
                </div>

                <!-- detail -->
                @if (expandedId == app.ApplicationId)
                {
                    <div class="card-body pt-0 border-top">
                        <div class="row g-3">
                            <!-- detail -->
                            <div class="col-md-6">
                                <h6 style="color:var(--cb-green-dark); font-size:0.8rem; text-transform:uppercase; letter-spacing:0.08em;">Applicant Details</h6>
                                <table class="table table-sm mb-0" style="font-size:0.85rem;">
                                    <tr><td style="color:var(--cb-muted); width:40%;">Name</td><td>@app.FullName</td></tr>
                                    <tr><td style="color:var(--cb-muted);">Email</td><td>@app.Email</td></tr>
                                    <tr><td style="color:var(--cb-muted);">Phone</td><td>@(app.Phone ?? "—")</td></tr>
                                    <tr><td style="color:var(--cb-muted);">DOB</td><td>@(app.DateOfBirth?.ToString("MMM d, yyyy") ?? "—")</td></tr>
                                    <tr><td style="color:var(--cb-muted);">Address</td><td>@(app.Address ?? "—") @app.PostalCode</td></tr>
                                    <tr><td style="color:var(--cb-muted);">Occupation</td><td>@(app.Occupation ?? "—")</td></tr>
                                    <tr><td style="color:var(--cb-muted);">Company</td><td>@(app.CompanyName ?? "—")</td></tr>
                                    <tr><td style="color:var(--cb-muted);">Membership</td><td><strong>@app.RequestedType</strong></td></tr>
                                </table>
                            </div>

                            <!-- info about Sponsors -->
                            <div class="col-md-6">
                                <h6 style="color:var(--cb-green-dark); font-size:0.8rem; text-transform:uppercase; letter-spacing:0.08em;">Sponsors</h6>
                                <div class="p-2 rounded mb-2" style="background:var(--cb-cream); font-size:0.83rem;">
                                    <strong>Sponsor 1:</strong> @(app.Sponsor1Name ?? "—")
                                    @if (!string.IsNullOrEmpty(app.Sponsor1MemberNumber)) { <span class="text-muted ms-1">(#@app.Sponsor1MemberNumber)</span> }
                                    <br/>
                                    <span style="color:var(--cb-muted); font-size:0.78rem;">Signed: @(app.Sponsor1Signature ?? "—")</span>
                                </div>
                                <div class="p-2 rounded" style="background:var(--cb-cream); font-size:0.83rem;">
                                    <strong>Sponsor 2:</strong> @(app.Sponsor2Name ?? "—")
                                    @if (!string.IsNullOrEmpty(app.Sponsor2MemberNumber)) { <span class="text-muted ms-1">(#@app.Sponsor2MemberNumber)</span> }
                                    <br/>
                                    <span style="color:var(--cb-muted); font-size:0.78rem;">Signed: @(app.Sponsor2Signature ?? "—")</span>
                                </div>

                                <!-- commitee notes -->
                                <div class="mt-3">
                                    <label class="form-label">Committee Notes</label>
                                    <textarea rows="2" class="form-control"
                                              placeholder="Add review notes..."
                                              value="@GetNotes(app.ApplicationId)"
                                              @oninput="e => SetNotes(app.ApplicationId, e.Value?.ToString() ?? string.Empty)">
                                    </textarea>
                                </div>
                            </div>

                            <!-- action to take -->
                            <div class="col-12">
                                <hr class="gold-divider" />
                                <div class="d-flex gap-2 flex-wrap">
                                    <button class="btn btn-sm btn-green px-3" @onclick="() => UpdateStatus(app, ApplicationStatus.UnderReview)">
                                        <i class="bi bi-eye me-1"></i>Under Review
                                    </button>
                                    <button @onclick="() => UpdateStatus(app, ApplicationStatus.Accepted)" class="btn btn-sm btn-gold px-3">
                                        <i class="bi bi-check-circle me-1"></i>Accept
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger px-3" @onclick="() => UpdateStatus(app, ApplicationStatus.Denied)">
                                        <i class="bi bi-x-circle me-1"></i>Deny
                                    </button>
                                    <button class="btn btn-sm btn-outline-green px-3" @onclick="() => UpdateStatus(app, ApplicationStatus.OnHold)">
                                        <i class="bi bi-pause-circle me-1"></i>On Hold
                                    </button>
                                    <button class="btn btn-sm btn-outline-green px-3" @onclick="() => UpdateStatus(app, ApplicationStatus.Waitlisted)">
                                        <i class="bi bi-hourglass-split me-1"></i>Waitlist
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
}

@code {
    private List<MembershipApplication> applications = new();
    // only one card open at a time, null = all collapsed
    private int? expandedId;
    string searchTerm  = "";
    private string filterStatus = "";
    private string actionMsg    = "";
    // noteDraft holds unsaved note text per application - doesnt persist until UpdateStatus is called
    private Dictionary<int, string> noteDraft = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadApplications();
    }

    private async Task LoadApplications()
    {
        await using var db = DBFactory.CreateDbContext();
        applications = await db.MembershipApplications
            .OrderByDescending(a => a.SubmittedAt)
            .ToListAsync();
    }

    private IEnumerable<MembershipApplication> FilteredApplications()
    {
        var q = applications.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var t = searchTerm.ToLower();
            q = q.Where(a => a.FullName.ToLower().Contains(t) || a.Email.ToLower().Contains(t));
        }

        if (!string.IsNullOrEmpty(filterStatus) && Enum.TryParse<ApplicationStatus>(filterStatus, out var s))
            q = q.Where(a => a.Status == s);

        return q;
    }

    private void ToggleExpand(int id)
    {
        expandedId = expandedId == id ? null : id;
    }

    private string GetNotes(int id) => noteDraft.TryGetValue(id, out var n) ? n : "";
    private void SetNotes(int id, string val) => noteDraft[id] = val;

    // saves note + reviewer name + timestamp all in one shot when status changes
    private async Task UpdateStatus(MembershipApplication app, ApplicationStatus newStatus)
    {
        app.Status     = newStatus;
        app.ReviewedAt = DateTime.UtcNow;
        app.ReviewedBy = UserServ.CurrentUser?.Username;

        if (noteDraft.TryGetValue(app.ApplicationId, out var note) && !string.IsNullOrWhiteSpace(note))
            app.ReviewNotes = note;

        await using var db = DBFactory.CreateDbContext();
        db.MembershipApplications.Update(app);
        await db.SaveChangesAsync();
        await AuditSvc.LogAsync(
            UserServ.CurrentUser!.Username,
            "UpdateApplicationStatus",
            "Application",
            app.ApplicationId,
            app.FullName + " → " + newStatus.ToString()
        );
        actionMsg = "Application for " + app.FullName + " updated to " + newStatus.ToString() + ".";
        await LoadApplications();

        // auto-dismiss action message after 3 secs
        await Task.Delay(3000);
        actionMsg = "";
    }

    private bool IsAuthorized() => UserServ.CurrentUser?.Role is "Admin" or "Staff";

    private string StatusColor(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Accepted    => "var(--cb-success)",
        ApplicationStatus.Denied      => "var(--cb-danger)",
        ApplicationStatus.UnderReview => "var(--cb-gold)",
        ApplicationStatus.OnHold      => "#e67e22",
        ApplicationStatus.Waitlisted  => "#8e44ad",
        _                             => "var(--cb-muted)"
    };

    private string StatusBg(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Accepted    => "rgba(39,174,96,0.12)",
        ApplicationStatus.Denied      => "rgba(192,57,43,0.12)",
        ApplicationStatus.UnderReview => "rgba(201,168,76,0.15)",
        ApplicationStatus.OnHold      => "rgba(230,126,34,0.12)",
        ApplicationStatus.Waitlisted  => "rgba(142,68,173,0.1)",
        _                             => "rgba(100,100,100,0.1)"
    };

    private string StatusTextColor(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Accepted    => "#1a6b3e",
        ApplicationStatus.Denied      => "var(--cb-danger)",
        ApplicationStatus.UnderReview => "#8B6914",
        ApplicationStatus.OnHold      => "#9a5f0a",
        ApplicationStatus.Waitlisted  => "#6c3483",
        _                             => "var(--cb-muted)"
    };
}
