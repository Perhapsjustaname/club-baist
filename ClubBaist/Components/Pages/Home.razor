                <circle cx="152" cy="230" r="2.2" fill="rgba(0,0,0,0.09)"/>
                <circle cx="148" cy="237" r="2.2" fill="rgba(0,0,0,0.09)"/>
                <circle cx="142" cy="237" r="2.2" fill="rgba(0,0,0,0.09)"/>
                <circle cx="154" cy="237" r="2.2" fill="rgba(0,0,0,0.09)"/>
                <circle cx="148" cy="228" r="2" fill="rgba(0,0,0,0.07)"/>
