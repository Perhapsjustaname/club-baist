}

<style>
    /* ── Hero swinging club ── */
    .hero-golf-anim {
        position: absolute;
        right: 2.5rem;
        bottom: 0;
        opacity: 0.55;
        pointer-events: none;
        z-index: 1;
    }

    .hero-swing-group {
        transform-box: fill-box;
        transform-origin: 32px 28px;
        animation: golf-swing 2.6s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    }

    @@keyframes golf-swing {
        0%   { transform: rotate(-48deg); }
        35%  { transform: rotate(-48deg); }
        62%  { transform: rotate(28deg); }
        72%  { transform: rotate(28deg); }
        100% { transform: rotate(-48deg); }
    }

    /* ── Spinning golf ball (dashboard) ── */
    .spin-ball-wrap {
        display: flex;
        justify-content: flex-end;
        margin-bottom: -1.2rem;
        padding-right: 0.5rem;
    }

    .spin-ball-svg {
        animation: ball-spin 3.5s linear infinite;
        filter: drop-shadow(0 2px 6px rgba(127,85,57,0.15));
    }

    @@keyframes ball-spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }
</style>

@code {
    private MemberProfile? memberProfile;
    private List<TeeTimeBooking>? upcomingBookings;
    int roundsCount = 0;
    private int bookingsCount = 0;

    protected override async Task OnInitializedAsync()
    {
        if (UserServ.IsLoggedIn && UserServ.CurrentUser != null)
        {
            await using var db = DBFactory.CreateDbContext();

            memberProfile = await db.MemberProfiles
                .FirstOrDefaultAsync(m => m.UserId == UserServ.CurrentUser.UserId);

            if (memberProfile != null)
            {
                DateOnly today = DateOnly.FromDateTime(DateTime.Today);
                upcomingBookings = await db.TeeTimeBookings
                    .Where(b => b.MemberProfileId == memberProfile.MemberProfileId
                                && b.TeeDate >= today
                                && b.Status == BookingStatus.Confirmed)
                    .OrderBy(b => b.TeeDate).ThenBy(b => b.TeeTime)
                    .Take(5)
                    .ToListAsync();

                roundsCount = await db.PlayerRounds
                    .CountAsync(r => r.MemberProfileId == memberProfile.MemberProfileId
                                    && r.RoundDate.Year == DateTime.Now.Year);

                bookingsCount = await db.TeeTimeBookings
                    .CountAsync(b => b.MemberProfileId == memberProfile.MemberProfileId
                                     && b.TeeDate.Year == DateTime.Now.Year);
            }
            else
            {
                upcomingBookings = new();
            }
        }
    }

    private string GetSeasonStatus()
    {
        var m = DateTime.Now.Month;
        return m is >= 3 and <= 9
            ? "Golf Season Open"
            : "Golf Season Closed (Mar\u2013Sep)";
    }

    private string GetTierBadgeClass() => memberProfile?.Tier switch
    {
        MembershipTier.Gold   => "status-chip badge-gold",
        MembershipTier.Silver => "status-chip badge-silver",
        MembershipTier.Bronze => "status-chip badge-bronze",
        _                     => "status-chip"
    };
}
