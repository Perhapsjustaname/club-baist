    <div class="hero-section">
        <!-- Animated golf club swing (develoepd with ai)-->
        <div class="hero-golf-anim" aria-hidden="true">
            <svg viewBox="0 0 170 280" xmlns="http://www.w3.org/2000/svg" width="170" height="280">
                <!-- Swinging club group, pivot at grip -->
                <g class="hero-swing-group">
                    <!-- Grip cap -->
                    <circle cx="32" cy="28" r="6" fill="rgba(230,204,178,0.55)"/>
                    <!-- Shaft -->
                    <line x1="32" y1="28" x2="122" y2="205"
                          stroke="rgba(230,204,178,0.75)" stroke-width="4" stroke-linecap="round"/>
                    <!-- Hosel -->
                    <ellipse cx="123" cy="207" rx="5" ry="6" fill="rgba(221,184,146,0.8)"/>
                    <!-- Iron club head -->
                    <rect x="112" y="208" width="36" height="13" rx="5"
