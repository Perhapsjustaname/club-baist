                        <div class="stat-label">Holes</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card" style="border-left-color:var(--cb-green);">
                        <div class="stat-value">71/73</div>
                        <div class="stat-label">Par (Men/Women)</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card" style="border-left-color:#aaa;">
                        <div class="stat-value">6,442</div>
                        <div class="stat-label">Yards (Blue Tee)</div>
                    </div>
                </div>
            </div>
